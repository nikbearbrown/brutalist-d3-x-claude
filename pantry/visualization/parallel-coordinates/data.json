{
  "_schema": {
    "description": "28 humanitarian AI programs measured across 7 numerical dimensions. Each record is one line in the parallel coordinates plot. The 'type' field determines line color.",
    "fields": {
      "dimensions[].id":       "string — key matching data record fields",
      "dimensions[].label":    "string — axis header label",
      "dimensions[].desc":     "string — description shown in tooltip",
      "dimensions[].inverted": "boolean — true if lower values are better (annotated on axis)",
      "data[].id":             "string — unique record identifier",
      "data[].name":           "string — program name shown in tooltip",
      "data[].type":           "string — category determining line color",
      "data[].{dimId}":        "number — value for each dimension"
    },
    "replace": "Replace dimension ids and labels to match your variables. Replace data records with your observations. Keep all dimension values numeric. Reorder dimensions array to change initial axis order."
  },
  "dimensions": [
    { "id": "beneficiaries", "label": "Beneficiaries (k)", "desc": "People reached, thousands",         "inverted": false },
    { "id": "funding",       "label": "Funding ($M)",       "desc": "Annual budget, USD millions",       "inverted": false },
    { "id": "efficiency",    "label": "Efficiency (%)",     "desc": "Value delivered per dollar spent",  "inverted": false },
    { "id": "responseTime",  "label": "Response (days)",    "desc": "Alert to delivery — lower is better","inverted": true  },
    { "id": "aiAccuracy",    "label": "AI Accuracy (%)",    "desc": "Model prediction accuracy",         "inverted": false },
    { "id": "staffCount",    "label": "Staff",              "desc": "Total field and ops staff",         "inverted": false },
    { "id": "coverage",      "label": "Coverage (%)",       "desc": "% of target population reached",    "inverted": false }
  ],
  "types": [
    { "id": "Emergency Response",      "color": "#B52C2C" },
    { "id": "Food Security",           "color": "#5C3317" },
    { "id": "Health & WASH",           "color": "#4A4D4F" },
    { "id": "Protection & Education",  "color": "#797C7F" }
  ],
